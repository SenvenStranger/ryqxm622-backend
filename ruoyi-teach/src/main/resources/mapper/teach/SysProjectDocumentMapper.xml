<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.teach.mapper.SysProjectDocumentMapper">

    <resultMap type="com.ruoyi.teach.domain.SysProjectDocument" id="SysProjectDocumentResult">
        <result property="docId" column="doc_id"/>
        <result property="projectId" column="project_id"/>
        <result property="projectName" column="project_name"/>
        <result property="docName" column="doc_name"/>
        <result property="docType" column="doc_type"/>
        <result property="fileType" column="file_type"/>
        <result property="docSize" column="doc_size"/>
        <result property="filePath" column="file_path"/>
        <result property="version" column="version"/>
        <result property="description" column="description"/>
        <result property="userName" column="user_name"/>
        <result property="uploadTime" column="upload_time"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectDocumentVo">
        select d.doc_id, d.project_id, p.project_name, d.doc_name, d.doc_type,
               d.file_type, d.doc_size, d.file_path, d.version, d.description,
               d.user_name, d.upload_time, d.remark,
               d.create_by, d.create_time, d.update_by, d.update_time
        from sys_project_document d
        left join sys_scientific_project p on d.project_id = p.project_id
    </sql>

    <select id="selectDocumentList" parameterType="com.ruoyi.teach.domain.SysProjectDocument" resultMap="SysProjectDocumentResult">
        <include refid="selectDocumentVo"/>
        <where>
            <if test="projectId != null">and d.project_id = #{projectId}</if>
            <if test="docType != null and docType != ''">and d.doc_type = #{docType}</if>
            <if test="docName != null and docName != ''">and d.doc_name like concat('%', #{docName}, '%')</if>
        </where>
        order by d.upload_time desc
    </select>

    <select id="selectDocumentById" parameterType="Long" resultMap="SysProjectDocumentResult">
        <include refid="selectDocumentVo"/>
        where d.doc_id = #{docId}
    </select>

    <insert id="insertDocument" parameterType="com.ruoyi.teach.domain.SysProjectDocument" useGeneratedKeys="true" keyProperty="docId">
        insert into sys_project_document
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="docName != null">doc_name,</if>
            <if test="docType != null">doc_type,</if>
            <if test="fileType != null">file_type,</if>
            <if test="docSize != null">doc_size,</if>
            <if test="filePath != null">file_path,</if>
            <if test="version != null">version,</if>
            <if test="description != null">description,</if>
            <if test="userName != null">user_name,</if>
            <if test="uploadTime != null">upload_time,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="docName != null">#{docName},</if>
            <if test="docType != null">#{docType},</if>
            <if test="fileType != null">#{fileType},</if>
            <if test="docSize != null">#{docSize},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="version != null">#{version},</if>
            <if test="description != null">#{description},</if>
            <if test="userName != null">#{userName},</if>
            <if test="uploadTime != null">#{uploadTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateDocument" parameterType="com.ruoyi.teach.domain.SysProjectDocument">
        update sys_project_document
        <trim prefix="SET" suffixOverrides=",">
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="docName != null">doc_name = #{docName},</if>
            <if test="docType != null">doc_type = #{docType},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="docSize != null">doc_size = #{docSize},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="version != null">version = #{version},</if>
            <if test="description != null">description = #{description},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
        </trim>
        where doc_id = #{docId}
    </update>

    <delete id="deleteDocumentById" parameterType="Long">
        delete from sys_project_document where doc_id = #{docId}
    </delete>

    <delete id="deleteDocumentByIds" parameterType="Long">
        delete from sys_project_document where doc_id in
        <foreach item="docId" collection="array" open="(" separator="," close=")">
            #{docId}
        </foreach>
    </delete>

</mapper>
